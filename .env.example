# AuthCoreAdmin 构建环境变量（复制为 .env.{mode}，勿提交真实凭据）

# UC API（compose/dev 可留空走同域或 vite proxy）
UC_SERVER=

# 当前管理后台域名 → 请求头 HtyHost / wx_qr_login 查 hty_apps
HOST=admin.example.com

# 登录方式（二选一，构建时决定独立登录页）：
#   password — 仅用户名密码（upctl-compose 默认）
#   wx       — 仅微信扫码（moicen / huiwings 正式与测试服）
LOGIN_MODE=password

# 微信开放平台 AppID（仅 LOGIN_MODE=wx 时设置）
WX_APP=

# 扫码回调域名（须在开放平台注册）；默认同 HOST
# 若与 HOST 不同，需在 redirect 域 nginx 配置桥接（如 /admin-wx-login → admin 域 /wx-login）
WX_REDIRECT_HOST=

# 回调路径（默认：同域 wx-login，跨域 admin-wx-login）
WX_LOGIN_BRIDGE_PATH=

# 允许进入管理后台的角色 key，逗号分隔
ADMIN_ALLOWED_ROLE_KEYS=ADMIN

# password 模式下是否显示 union_id 表单（compose 可 true）
ENABLE_DEV_UNIONID_LOGIN=true

# SPA base（compose 为 /admin/）
VITE_BASE=/
